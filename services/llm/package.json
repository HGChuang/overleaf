{
  "name": "@overleaf/llm",
  "description": "The backend API that powers Overleaf llm",
  "private": true,
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "dev": "tsx watch app.ts",
    "test:acceptance": "npm run test:acceptance:_run -- --grep=$MOCHA_GREP",
    "test:unit": "npm run test:unit:_run -- --grep=$MOCHA_GREP",
    "nodemon": "tsx watch app.ts",
    "test:acceptance:_run": "LOG_LEVEL=fatal NODE_OPTIONS=--import=tsx mocha --require ./test/setup.ts --reporter spec --timeout 15000 --exit $@ \"test/acceptance/**/*.ts\"",
    "test:unit:_run": "LOG_LEVEL=fatal NODE_OPTIONS=--import=tsx mocha --require ./test/setup.ts --reporter spec --exit $@ \"test/unit/**/*.ts\"",
    "lint": "eslint --max-warnings 0 --format unix .",
    "format": "prettier --list-different $PWD/'**/*.ts'",
    "format:fix": "prettier --write $PWD/'**/*.ts'",
    "lint:fix": "eslint --fix .",
    "types:check": "tsc --noEmit"
  },
  "version": "1.0.0",
  "directories": {
    "test": "test"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@overleaf/settings": "*",
    "axios": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "mongoose": "^8.16.3",
    "openai": "^5.11.0",
    "partial-json": "^0.1.7",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "chai": "^4.3.6",
    "chai-as-promised": "^7.1.1",
    "ioredis-mock": "^8.13.1",
    "mocha": "^10.2.0",
    "sinon": "^9.2.4",
    "sinon-chai": "^3.7.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
