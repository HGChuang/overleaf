{
  "name": "@overleaf/llm",
  "description": "The backend API that powers Overleaf llm",
  "private": true,
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "test:acceptance": "npm run test:acceptance:_run -- --grep=$MOCHA_GREP",
    "test:unit": "npm run test:unit:_run -- --grep=$MOCHA_GREP",
    "nodemon": "node --watch app.js",
    "test:acceptance:_run": "LOG_LEVEL=fatal mocha --loader=esmock --require ./test/setup.js --recursive --reporter spec --timeout 15000 --exit $@ test/acceptance/js",
    "test:unit:_run": "LOG_LEVEL=fatal mocha --loader=esmock --require ./test/setup.js --recursive --reporter spec $@ test/unit/js",
    "lint": "eslint --max-warnings 0 --format unix .",
    "format": "prettier --list-different $PWD/'**/*.js'",
    "format:fix": "prettier --write $PWD/'**/*.js'",
    "lint:fix": "eslint --fix .",
    "types:check": "tsc --noEmit"
  },
  "version": "1.0.0",
  "directories": {
    "test": "test"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint": "^1.1.3",
    "@langchain/openai": "^1.5.5",
    "@overleaf/settings": "*",
    "axios": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "mongoose": "^8.16.3",
    "nodemon": "^3.1.10",
    "openai": "^5.11.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "chai": "^4.3.6",
    "chai-as-promised": "^7.1.1",
    "esmock": "^2.7.6",
    "ioredis-mock": "^8.13.1",
    "mocha": "^10.2.0",
    "sinon": "^9.2.4",
    "sinon-chai": "^3.7.0"
  }
}
